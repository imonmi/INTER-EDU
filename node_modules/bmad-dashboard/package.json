{
  "name": "bmad-dashboard",
  "version": "1.0.19",
  "description": "Local dashboard to view BMAD project state (phase, artifacts, stories, sprint) in real time",
  "type": "module",
  "bin": {
    "bmad-dashboard": "server/index.js"
  },
  "files": [
    "server",
    "dist",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caionormando/bmad-dashboard.git"
  },
  "keywords": [
    "bmad",
    "dashboard",
    "project-status",
    "cursor",
    "planning",
    "prd",
    "epics",
    "sprint"
  ],
  "author": "caionormando",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:server": "vitest run server",
    "test:components": "vitest run src",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.1",
    "vitest": "^2.1.9"
  }
}
